{"texts": ["HỢP ĐỒNG ĐẠI LÝ\n\nĐiều 1:\nĐại lý cấp 1 phải đạt doanh số tối thiểu\n1 tỷ đồng/tháng.\n\nĐiều 2:\nKhông được phân phối sản phẩm giả mạo.\n\nĐiều 3:\nThanh toán trong vòng 15 ngày kể từ ngày xuất hoá đơn.\n\nĐiều 4:\nVi phạm hợp đồng sẽ bị chấm dứt hợp tác."], "metas": [{"source_id": "3a19542f9c341008", "file_name": "24e4a328d13b4f1bb91e0e3b1b73df7f_kshgi3pm.txt", "file_extension": "txt", "file_size_bytes": 337, "absolute_path": "/tmp/24e4a328d13b4f1bb91e0e3b1b73df7f_kshgi3pm.txt", "document_type": "file", "chunk_idx": 0}], "corpus": [["hợp", "đồng", "đại", "lý", "điều", "1:", "đại", "lý", "cấp", "1", "phải", "đạt", "doanh", "số", "tối", "thiểu", "1", "tỷ", "đồng/tháng.", "điều", "2:", "không", "được", "phân", "phối", "sản", "phẩm", "giả", "mạo.", "điều", "3:", "thanh", "toán", "trong", "vòng", "15", "ngày", "kể", "từ", "ngày", "xuất", "hoá", "đơn.", "điều", "4:", "vi", "phạm", "hợp", "đồng", "sẽ", "bị", "chấm", "dứt", "hợp", "tác."]], "hashes": ["3a19542f9c341008"]}